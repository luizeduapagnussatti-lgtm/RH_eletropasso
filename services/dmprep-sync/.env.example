NODE_ENV=production
LOG_LEVEL=info

# UNC path to MOVIMENT.txt (legacy — disabled when DMPREP_MOVIMENT_ENABLED=false).
DMPREP_MOVIMENT_PATH=\\\\192.168.15.69\\C$\\Program Files (x86)\\Dimep\\DMPREP\\MOVIMENT.txt
# Disable MOVIMENT.txt polling; punches come from WatchComm TCP on the HR server.
DMPREP_MOVIMENT_ENABLED=false
# UNC or local path to DIMEP.MDB (required for employee import).
DMPREP_MDB_PATH=\\\\192.168.15.69\\C$\\util dimep\\BD ELETROPASSO\\DIMEP.MDB
DMPREP_DEVICE_SERIAL=00003004820030709
DMPREP_POLL_INTERVAL_MS=3600000
DMPREP_STATE_PATH=E:\\RH_eletropasso\\data\\dmprep-sync\\state.json
DMPREP_BATCH_SIZE=100

# Manual sync HTTP control plane (used by OpenHR "Sincronizar DMPREP" button).
DMPREP_HTTP_ENABLED=true
DMPREP_HTTP_HOST=127.0.0.1
DMPREP_HTTP_PORT=3099
# Defaults to PUNCH_INGEST_API_KEY when omitted.
DMPREP_HTTP_API_KEY=

# Supabase credentials for employee import from DIMEP.MDB.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
DMPREP_IMPORT_TEMP_PASSWORD=DmprepImport2026!

# Same credentials used by rep-gateway forwarding.
PUNCH_INGEST_URL=https://YOUR_PROJECT.supabase.co/functions/v1/ingest-punches
PUNCH_INGEST_API_KEY=
PUNCH_INGEST_ORGANIZATION_ID=
PUNCH_INGEST_TIMEOUT_MS=15000

# WatchComm TCP poller (manual "Collect punches" + hourly Task Scheduler).
WATCHCOMM_POLLER_SCRIPT=C:\\xampp\\htdocs\\RH_eletropasso\\scripts\\watchcomm-poller\\Run-WatchCommPoller.ps1
WATCHCOMM_CONFIG_PATH=E:\\RH_eletropasso\\config\\watchcomm-poller.json
WATCHCOMM_RESULT_PATH=E:\\RH_eletropasso\\logs\\rep-gateway\\watchcomm-poller\\last-cycle-result.json
