{
  "name": "dmprep-sync",
  "version": "1.0.0",
  "description": "Importa batidas do DMP REP (MOVIMENT.txt) para ingest-punches",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "dmprep",
    "dimep",
    "punch",
    "moviment"
  ],
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
