NODE_ENV=production
PORT=3002
LOG_LEVEL=info
REP_LOG_FILE=/data/logs/gateway.jsonl

# PrintPoint III autorizado
REP_ALLOWED_IPS=192.168.15.201
# Docker Desktop NAT: só é aceito quando a URL contém o serial configurado.
REP_NAT_IPS=172.19.0.1
REP_DEVICE_SERIAL=00003004820030709
REP_CAPTURE_DIR=/data/captures
REP_RETENTION_DAYS=30
REP_MAX_CAPTURE_FILES=10000
REP_MAX_BODY_BYTES=1048576

# ACK de descoberta (ajustar depois da primeira captura)
REP_ACK_STATUS=200
REP_ACK_CONTENT_TYPE=text/plain; charset=utf-8
REP_ACK_BODY=OK
# rsa-pkcs1-probe é somente para descoberta controlada do handshake.
REP_ACK_MODE=plain
REP_ACK_RSA_PLAINTEXT_HEX=
REP_ACK_RSA_PROBE_HEX_CANDIDATES=empty
REP_ACK_RSA_PROBE_VARIANTS=pkcs1-binary

# discovery não promove eventos para punches
REP_SECURITY_MODE=discovery
REP_PROTOCOL_PROFILE=discovery

# Chave pública de comunicação exportada pelo equipamento.
# Preencher somente no .env operacional (não versionar segredo/configuração local).
REP_RSA_MODULUS_HEX=
REP_RSA_EXPONENT_HEX=010001
REP_SIGNATURE_HEADER=x-signature
REP_SIGNATURE_ENCODING=base64
REP_RSA_HASH=sha256
REP_RSA_PADDING=pkcs1
REP_RSA_PSS_SALT_LENGTH=-1

# Só habilitar após comprovar protocolo e RSA
REP_FORWARD_ENABLED=false
PUNCH_INGEST_URL=http://host.docker.internal:54321/functions/v1/ingest-punches
PUNCH_INGEST_API_KEY=
PUNCH_INGEST_ORGANIZATION_ID=
PUNCH_INGEST_TIMEOUT_MS=5000
REP_REPLAY_TTL_SECONDS=172800
REP_REPLAY_MAX_ENTRIES=10000
