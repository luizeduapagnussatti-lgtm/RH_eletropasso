{
  "name": "rep-gateway",
  "version": "1.0.0",
  "description": "Gateway seguro para eventos Client Rest do REP PrintPoint III",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "rep",
    "printpoint",
    "punch-clock"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
